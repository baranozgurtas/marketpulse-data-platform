FROM bitnamilegacy/spark:3.5

USER root

# snowflake-connector-python is left unpinned here: the pinned 3.6.0
# has no prebuilt ARM64 wheel and the base image lacks a compiler.
RUN pip install --no-cache-dir \
    pyspark==3.5.0 \
    snowflake-connector-python

USER 1001

# Bake Spark jobs into the image for Kubernetes (compose mounts the
# live folder over this path for local development).
COPY spark_jobs/ /opt/spark-jobs/
