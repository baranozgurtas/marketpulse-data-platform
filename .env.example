# ============================================================
# MarketPulse - Environment Variables
# ============================================================
# Copy this file to .env and fill in your Snowflake credentials.
# .env is gitignored - NEVER commit real credentials.
#
# To export into your shell for dbt:
#   set -a && source .env && set +a
# ============================================================

# Account identifier, e.g. "ORGNAME-ACCOUNTNAME" or "ab12345.eu-central-1.aws"
SNOWFLAKE_ACCOUNT=your_account.region.cloud

SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password

# Defaults match the repository configuration.
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_DATABASE=MARKETPULSE
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=CURATED
